---
import CardOne from '../assets/card-one.svg'
import CardTwo from '../assets/card-two.svg'
import CardThree from '../assets/card-three.svg'
import CardFour from '../assets/card-four.svg'
import CardFive from '../assets/card-five.svg'
import CardSix from '../assets/card-six.svg'
import CardSeven from '../assets/card-seven.svg'
import CardEight from '../assets/card-eight.svg'
---

<section class="product-feature">
  <div class="container">
    <div class="feature-list card-number-one">
      <div class="center">
        <small>ingestion</small>
        <h2 class="h2-title">Record audit events without coupling the app to storage details.</h2>
        <p>
          AuditTrail’s API accepts validated events, scopes them to a project,
          and preserves an append-only timeline that can power dashboards and investigations.
        </p>
      </div>
      <div class="feature-cards row">
        <div class="one-half column right">
          <img src={CardOne} alt="Audit event timeline" />
        </div>
        <div class="one-half column multi-cards left">
          <img src={CardTwo} alt="Project-scoped events" />
          <img src={CardThree} alt="Validation boundary" class="round" />
          <img src={CardEight} alt="Cursor pagination" class="round" />
        </div>
      </div>
    </div>

    <div class="feature-list card-number-two">
      <div class="center">
        <small>governance</small>
        <h2 class="h2-title">Keep access, invitations, and exports in the same controlled workflow.</h2>
        <p>
          Browser sessions, organization roles, invitations, and export jobs are
          modeled together so teams can manage evidence without jumping between tools.
        </p>
      </div>
      <div class="feature-cards row">
        <div class="one-half column multi-cards right">
          <img src={CardSeven} class="has-border" alt="Workspace controls" />
          <img src={CardSix} alt="Invitation flow" class="round" />
          <img src={CardFour} alt="Export jobs" class="round" />
        </div>
        <div class="one-half column left">
          <img src={CardFive} alt="Browser session app shell" />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
.product-feature{
  background-color: #eef5ff;
  padding: 10px 0 90px 0;
  .feature-list {
    margin-top: 140px;
  }
  .feature-cards{
    padding-top: 40px;
  }

  .h2-title, p{
    margin: 20px auto;
  }
  .h2-title{
    max-width: 680px;
  }
  p{
    max-width: 760px;
  }
  small{
    text-transform: uppercase;
    font-weight: 900;
    color: #5b6b84;
    font-size: 1.5rem;
  }

   img{
      width: 320px;
      border-radius: 20px;
      &.round{
          border-radius: 50px;
      }
      &:not(.has-border){
          border: 1px solid #d6e2f3;
      }
   }

  .right{
      text-align: right;
  }
  .left{
      text-align: left;
  }

  .card-number-one .multi-cards img,
  .card-number-two .multi-cards img{
      margin: 15px 0;
     &:nth-child(1){
      transform: rotate(-2deg);
     }
      &:nth-child(3){
      transform: rotate(10deg);
     }
  }

  @media (max-width:700px) {
    img{
      width: 250px;
    }
    .right, .left{
      text-align: center;
    }
  }
}
</style>
