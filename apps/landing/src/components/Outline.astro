---
const signInLink = "http://localhost:3000/auth/sign-in";
---

<section class="product-outline padded">
  <div class="container">
    <div class="text-container center">
      <h2 class="h1-title">Start using AuditTrail in minutes</h2>
      <p>
        Sign in with a magic link, create your first organization, and start
        capturing events, invitations, and exports from one place.
      </p>

      <div class="content-form row">
        <a href={signInLink} class="button button-primary twelve columns">Open AuditTrail</a>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
.product-outline{
  background-color: #fff;
}
</style>
