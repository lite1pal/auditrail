---
import LinkedIn from '../assets/linkedin.svg'
import Twitter from '../assets/twitter.svg'
const repoLink = "https://github.com/denistarasenko/auditrail";

---

<footer>
  <div class="container row">
    <div class="footer-link flex js one-half column">
      <a href={repoLink}>Docs</a>
      <a href={repoLink}>Security</a>
      <a href={repoLink}>Privacy</a>
      <a href={repoLink}>Terms</a>
    </div>
    <div class="footer-note one-half column">
      <div class="u-pull-right">
        <div class="flex">
          <p>© AuditTrail</p>
          <a href={repoLink}><img src={Twitter} alt="Twitter icon"></a>
          <a href={repoLink}><img src={LinkedIn} alt="LinkedIn icon"></a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style lang="scss">
footer{
  padding: 40px 0;
  background-color: #fff;

  a, p{
    color: #222;
    font-size: 1.8rem;
  }
  .footer-link a{
    padding-right: 20px;
    text-decoration: none;
  }
  .container{
    padding: 30px;
    border-radius: 50px;

    .footer-note{
      a{
        padding-left: 20px;
        img{
          width: 28px;
        }
      }
    }
  }
  @media (max-width:700px) {
    .footer-link a{
      font-size: 1.6rem;
    }
      .flex{
          justify-content: center;
      }
      .column{
          padding: 10px 0;
      }
      .u-pull-right{
          float: none;
      }
  }
}

.flex{
  display: flex;
}
</style>
